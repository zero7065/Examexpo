/*
  ExamPadi AI — Firestore Security Rules
  ========================================
  WARNING: Payment verification is currently optimistic (client-side).
  Before taking real payments in production, replace with a Firebase
  Cloud Function webhook that verifies transactions via Paystack's server.
  See: https://paystack.com/docs/api/transaction-verify/

  Until then, payments/{paymentId} is create-by-owner, read-by-owner only.
  No update or delete allowed on payment records.
*/

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /payments/{paymentId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /userSessions/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}